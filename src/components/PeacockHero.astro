---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
---

<section id="hero" class="hero">
  <img
    src="/illustrations/hero-banner.png"
    alt={`${t(lang, 'hero.names')} — ${t(lang, 'hero.date')}. ${t(lang, 'hero.tagline')}`}
    class="hero-img"
  />
  <h1 class="sr-only">
    {t(lang, 'hero.welcome')} {t(lang, 'hero.names')} — {t(lang, 'hero.date')}. {t(lang, 'hero.tagline')}
  </h1>
</section>

<style>
  .hero {
    background-color: #1A3A3A;
    overflow: hidden;
    display: flex;
    justify-content: center;
    padding: 2rem 0;
  }

  .hero-img {
    width: 85%;
    height: auto;
    display: block;
    border: 2px solid rgba(200, 150, 62, 0.4);
    border-radius: 4px;
  }

  @media (max-width: 600px) {
    .hero {
      padding: 1rem 0;
    }

    .hero-img {
      width: 95%;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
