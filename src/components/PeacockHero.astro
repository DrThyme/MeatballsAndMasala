---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
---

<section id="hero" class="hero">
  <img
    src="/illustrations/hero-banner.png"
    alt={`${t(lang, 'hero.names')} — ${t(lang, 'hero.date')}. ${t(lang, 'hero.tagline')}`}
    class="hero-img"
  />
  <h1 class="sr-only">
    {t(lang, 'hero.welcome')} {t(lang, 'hero.names')} — {t(lang, 'hero.date')}. {t(lang, 'hero.tagline')}
  </h1>
</section>

<style>
  .hero {
    background-color: #1A3A3A;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 90vh;
    object-fit: contain;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
