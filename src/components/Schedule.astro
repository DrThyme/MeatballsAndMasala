---
import { t } from "../i18n/utils";
import MehndiCorner from "./motifs/MehndiCorner.astro";
import FloralDivider from "./motifs/FloralDivider.astro";
import Polaroid from "./Polaroid.astro";

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const day1Events = ["mehendi"];
const day2Events = ["ceremony", "dinner", "party"];
const eventsWithDetails = ["mehendi", "ceremony"];
---

<section id="schedule" class="section schedule reveal">
  <div class="schedule-motif-left">
    <MehndiCorner size="100px" color="var(--color-gold)" opacity={0.15} />
  </div>
  <div class="schedule-motif-right">
    <MehndiCorner size="100px" color="var(--color-gold)" opacity={0.15} flip />
  </div>
  <div class="schedule-polaroid-1">
    <Polaroid
      debugNum={3}
      rotation={6}
      caption="Mountain top!"
      placeholderColor="var(--color-gold)"
      hoverX="-30px"
      hoverY="20px"
    >
      <img
        src="/photos/couple-mountain.jpg"
        alt="Priya and Tim on a mountain"
      />
    </Polaroid>
  </div>
  <div class="schedule-polaroid-2">
    <Polaroid
      debugNum={4}
      rotation={-4}
      caption="Diwali vibes"
      placeholderColor="var(--color-blush)"
      hoverX="30px"
      hoverY="-20px"
    >
      <img src="/photos/couple-diwali.jpg" alt="Priya and Tim celebrating Diwali" />
    </Polaroid>
  </div>

  <h2 class="section-title">{t(lang, "schedule.title")}</h2>
  <div class="schedule-divider">
    <FloralDivider width="160px" />
  </div>

  <div class="timeline">
    <div class="day-header">
      <span class="day-date">{t(lang, "schedule.day1.date")}</span>
      <span class="day-title">{t(lang, "schedule.day1.title")}</span>
    </div>
    {
      day1Events.map((event) => (
        <div class="timeline-item">
          <div class="timeline-time">{t(lang, `schedule.${event}.time`)}</div>
          <div class="timeline-dot" />
          <div class="timeline-content">
            <h3>{t(lang, `schedule.${event}.title`)}</h3>
            <p>{t(lang, `schedule.${event}.description`)}</p>
            {eventsWithDetails.includes(event) && (
              <details class="event-details">
                <summary>{t(lang, `schedule.${event}.learnMore`)}</summary>
                <p class="event-explanation">
                  {t(lang, `schedule.${event}.explanation`)}
                </p>
              </details>
            )}
          </div>
        </div>
      ))
    }

    <div class="day-header">
      <span class="day-date">{t(lang, "schedule.day2.date")}</span>
      <span class="day-title">{t(lang, "schedule.day2.title")}</span>
    </div>
    {
      day2Events.map((event) => (
        <div class="timeline-item">
          <div class="timeline-time">{t(lang, `schedule.${event}.time`)}</div>
          <div class="timeline-dot" />
          <div class="timeline-content">
            <h3>{t(lang, `schedule.${event}.title`)}</h3>
            <p>{t(lang, `schedule.${event}.description`)}</p>
            {eventsWithDetails.includes(event) && (
              <details class="event-details">
                <summary>{t(lang, `schedule.${event}.learnMore`)}</summary>
                <p class="event-explanation">
                  {t(lang, `schedule.${event}.explanation`)}
                </p>
              </details>
            )}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .schedule {
    position: relative;
    z-index: 2;
  }

  .schedule-motif-left {
    position: absolute;
    top: 2rem;
    left: 2rem;
    pointer-events: none;
  }

  .schedule-motif-right {
    position: absolute;
    top: 2rem;
    right: 2rem;
    pointer-events: none;
  }

  .schedule-polaroid-1 {
    position: absolute;
    top: 4.6rem;
    right: max(1.5rem, calc(50% - 480px));
  }

  .schedule-polaroid-2 {
    position: absolute;
    bottom: 17.5rem;
    left: calc(50% - 560px);
  }

  .schedule-divider {
    text-align: center;
    margin-top: -1rem;
    margin-bottom: 2rem;
  }

  .timeline {
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 80px;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-gold);
  }

  .day-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 1.5rem;
    margin-top: 2rem;
    position: relative;
    z-index: 1;
    background-color: var(--color-cream);
    padding: 0.5rem 1rem;
    max-width: fit-content;
    margin-left: auto;
    margin-right: auto;
    border-radius: 8px;
  }

  .day-header:first-child {
    margin-top: 0;
  }

  .day-date {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .day-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-teal-dark);
    font-weight: 600;
  }

  .timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .timeline-time {
    flex-shrink: 0;
    width: 65px;
    text-align: right;
    font-weight: 600;
    color: var(--color-teal);
    padding-top: 0.15rem;
  }

  .timeline-dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-gold);
    border: 2px solid var(--color-cream);
    margin-top: 0.35rem;
    z-index: 1;
  }

  .timeline-content h3 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
    color: var(--color-teal-dark);
  }

  .timeline-content p {
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .event-details {
    margin-top: 0.5rem;
  }

  .event-details summary {
    font-family: var(--font-handwritten);
    font-size: 1rem;
    color: var(--color-gold);
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .event-details summary::before {
    content: "▸";
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .event-details[open] summary::before {
    transform: rotate(90deg);
  }

  .event-details summary::-webkit-details-marker {
    display: none;
  }

  .event-explanation {
    margin-top: 0.5rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-ivory);
    border-left: 3px solid var(--color-gold);
    border-radius: 0 6px 6px 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    .schedule-motif-left,
    .schedule-motif-right {
      display: none;
    }

    .timeline::before {
      left: 60px;
    }

    .timeline-time {
      width: 45px;
      font-size: 0.85rem;
    }
  }
</style>
