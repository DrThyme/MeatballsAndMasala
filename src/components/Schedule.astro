---
import { t } from '../i18n/utils';
import MehndiCorner from './motifs/MehndiCorner.astro';
import FloralDivider from './motifs/FloralDivider.astro';
import Polaroid from './Polaroid.astro';

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const day1Events = ['mehendi'];
const day2Events = ['ceremony', 'dinner', 'party'];
---

<section id="schedule" class="section schedule reveal">
  <div class="schedule-motif-left">
    <MehndiCorner size="100px" color="var(--color-gold)" opacity={0.15} />
  </div>
  <div class="schedule-motif-right">
    <MehndiCorner size="100px" color="var(--color-gold)" opacity={0.15} flip />
  </div>
  <div class="schedule-polaroid-1">
    <Polaroid rotation={6} placeholderColor="var(--color-gold)" />
  </div>
  <div class="schedule-polaroid-2">
    <Polaroid rotation={-4} placeholderColor="var(--color-teal)" />
  </div>

  <h2 class="section-title">{t(lang, 'schedule.title')}</h2>
  <div class="schedule-divider">
    <FloralDivider width="160px" />
  </div>

  <div class="timeline">
    <div class="day-header">
      <span class="day-date">{t(lang, 'schedule.day1.date')}</span>
      <span class="day-title">{t(lang, 'schedule.day1.title')}</span>
    </div>
    {day1Events.map((event) => (
      <div class="timeline-item">
        <div class="timeline-time">{t(lang, `schedule.${event}.time`)}</div>
        <div class="timeline-dot" />
        <div class="timeline-content">
          <h3>{t(lang, `schedule.${event}.title`)}</h3>
          <p>{t(lang, `schedule.${event}.description`)}</p>
        </div>
      </div>
    ))}

    <div class="day-header">
      <span class="day-date">{t(lang, 'schedule.day2.date')}</span>
      <span class="day-title">{t(lang, 'schedule.day2.title')}</span>
    </div>
    {day2Events.map((event) => (
      <div class="timeline-item">
        <div class="timeline-time">{t(lang, `schedule.${event}.time`)}</div>
        <div class="timeline-dot" />
        <div class="timeline-content">
          <h3>{t(lang, `schedule.${event}.title`)}</h3>
          <p>{t(lang, `schedule.${event}.description`)}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .schedule {
    position: relative;
    overflow: hidden;
  }

  .schedule-motif-left {
    position: absolute;
    top: 2rem;
    left: 2rem;
    pointer-events: none;
  }

  .schedule-motif-right {
    position: absolute;
    top: 2rem;
    right: 2rem;
    pointer-events: none;
  }

  .schedule-polaroid-1 {
    position: absolute;
    top: 6rem;
    right: max(1rem, calc(50% - 550px));
  }

  .schedule-polaroid-2 {
    position: absolute;
    bottom: 4rem;
    left: max(1rem, calc(50% - 550px));
  }

  .schedule-divider {
    text-align: center;
    margin-top: -1rem;
    margin-bottom: 2rem;
  }

  .timeline {
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 80px;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-gold);
  }

  .day-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 1.5rem;
    margin-top: 2rem;
    position: relative;
    z-index: 1;
    background-color: var(--color-cream);
    padding: 0.5rem 1rem;
    max-width: fit-content;
    margin-left: auto;
    margin-right: auto;
    border-radius: 8px;
  }

  .day-header:first-child {
    margin-top: 0;
  }

  .day-date {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .day-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-teal-dark);
    font-weight: 600;
  }

  .timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .timeline-time {
    flex-shrink: 0;
    width: 65px;
    text-align: right;
    font-weight: 600;
    color: var(--color-teal);
    padding-top: 0.15rem;
  }

  .timeline-dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-gold);
    border: 2px solid var(--color-cream);
    margin-top: 0.35rem;
    z-index: 1;
  }

  .timeline-content h3 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
    color: var(--color-teal-dark);
  }

  .timeline-content p {
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  @media (max-width: 600px) {
    .schedule-motif-left,
    .schedule-motif-right {
      display: none;
    }

    .timeline::before {
      left: 60px;
    }

    .timeline-time {
      width: 45px;
      font-size: 0.85rem;
    }
  }
</style>
